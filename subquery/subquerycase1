--11.WAQTD ENAME AND SALARY OF ALL THE EMPS WHO ARE EARNING MORE THAN MILLER BUT LESS THAN ALLEN --
SELECT ENAME,SAL FROM SCOTT.EMP WHERE SAL >(SELECT SAL FROM SCOTT.EMP WHERE ENAME ='MILLER' ) AND SAL<(SELECT SAL FROM SCOTT.EMP WHERE ENAME='ALLEN');

--12.WAQTD ALL THE DETAILS OF THE EMPS WORKING IN DEPT AND WORKING IN THE SAME DESIGNATION AS SMITH--
SELECT * FROM SCOTT.EMP WHERE DEPTNO IN(SELECT DEPTNO FROM SCOTT.EMP WHERE ENAME='SMITH') AND JOB IN (SELECT JOB FROM SCOTT.EMP WHERE ENAME='SMITH');


--13.WAQTD ALL THE DETAILS OF THE EMPS WORKING AS MANAGER IN THE SAME DEPT AS TURNER--
SELECT * FROM SCOTT.EMP WHERE JOB='MANAGER' AND DEPTNO=(SELECT DEPTNO FROM SCOTT.EMP WHERE ENAME='TURNER'); 

--14.WAQTD NAME AND HIREDATE OF THE EMPS HIRED AFTER 1980 AND BEFORE KING--

SELECT ENAME,HIREDATE FROM SCOTT.EMP WHERE HIREDATE > TO_DATE('31-DEC-1980','DD-MON-YYYY') AND HIREDATE < (SELECT HIREDATE FROM SCOTT.EMP WHERE ENAME='KING');

--15.WAQTD NAME AND SAL ALONG WITH ANNUAL SAL FOR ALL EMPS WHOS SAL IS LESS THAN BLAKE AND MORE THAN 3500--

SELECT ENAME,SAL,SAL*12 ANNUALSAL FROM SCOTT.EMP WHERE SAL >3500 AND SAL < (SELECT SAL FROM SCOTT.EMP WHERE ENAME='BLAKE');

--16.WAQTD ALL THE DETAILS OF EMPS WHO EARN MORE THAN SCOTT BUT LESS THAN KING--

SELECT * FROM SCOTT.EMP WHERE SAL < (SELECT SAL FROM SCOTT.EMP WHERE ENAME='KING') AND SAL > (SELECT SAL FROM SCOTT.EMP WHERE ENAME='SCOTT');

--17.WAQTD NAME OF THE EMPS WHOS NAME STARTS WITH 'A' AND WORKS IN THE SAME DEPT AS BLAKE --

SELECT ENAME FROM SCOTT.EMP WHERE DEPTNO IN (SELECT DEPTNO FROM SCOTT.EMP WHERE ENAME='BLAKE') AND ENAME LIKE 'A%';

--18.WAQTD NAME AND COMIM IF EMPS EARN COMISSION AND WORK IN THE SAME DESIGNATION AS SMITH--

SELECT ENAME,COMM FROM SCOTT.EMP WHERE JOB=(SELECT JOB FROM SCOTT.EMP WHERE ENAME='SMITH') AND COMM IS NOT NULL;

--19.WAQTD DETAILS OF ALL THE EMPS WORKING AS CLERK IN THE SAME DEPT AS TURNER--

SELECT * FROM SCOTT.EMP WHERE JOB ='CLERK' AND DEPTNO = (SELECT DEPTNO FROM SCOTT.EMP WHERE ENAME='TURNER');

--20.WAQTD ENAME, SAL AND JOB OF THE EMPS WHOS ANNUAL SALARY IS MORE THAN SMITH AND LESS THAN KING--

SELECT ENAME,SAL,JOB FROM SCOTT.EMP WHERE SAL*12 > (SELECT SAL*12 FROM SCOTT.EMP WHERE ENAME='SMITH') AND SAL*12 < (SELECT SAL*12 FROM SCOTT.EMP WHERE ENAME='KING');