--groupby clause--
SELECT DEPTNO,COUNT(*) FROM SCOTT.EMP WHERE JOB NOT IN 'PRESIDENT'
GROUP BY DEPTNO;


SELECT JOB,SUM(SAL) FROM SCOTT.EMP GROUP BY JOB;


SELECT DEPTNO,COUNT(*) FROM SCOTT.EMP WHERE JOB IN 'MANAGER' GROUP BY DEPTNO;


SELECT DEPTNO,AVG(SAL)FROM SCOTT.EMP WHERE DEPTNO NOT IN 10 GROUP BY DEPTNO;


SELECT COUNT(*),JOB FROM SCOTT.EMP WHERE ENAME LIKE '%A%' GROUP BY JOB;


SELECT DEPTNO,COUNT(*),AVG(SAL) FROM SCOTT.EMP WHERE SAL >2000 GROUP BY DEPTNO;


SELECT DEPTNO,SUM(SAL),COUNT(*) FROM SCOTT.EMP WHERE JOB IN 'SALESMAN' GROUP BY DEPTNO;



SELECT JOB,MAX(SAL) FROM SCOTT.EMP GROUP BY JOB;



SELECT MAX(SAL),DEPTNO FROM SCOTT.EMP GROUP BY DEPTNO;



SELECT DEPTNO,COUNT(SAL) FROM SCOTT.EMP GROUP BY DEPTNO; 


--HAVING CLAUSE--
SELECT DEPTNO,COUNT(*) FROM SCOTT.EMP WHERE JOB IN 'CLERK' GROUP BY DEPTNO HAVING COUNT(*)>=2 ;



SELECT DEPTNO,SUM(SAL) FROM SCOTT.EMP GROUP BY DEPTNO HAVING COUNT(*)<=4;


SELECT JOB,COUNT(*),SUM(SAL) FROM SCOTT.EMP WHERE SAL >1200 GROUP BY JOB HAVING SUM(SAL)>3800;



SELECT DEPTNO,COUNT(*) FROM SCOTT.EMP WHERE JOB IN 'MANAGER' GROUP BY DEPTNO HAVING COUNT(*)<= 2;




SELECT JOB,MAX(SAL) FROM SCOTT.EMP GROUP BY JOB HAVING MAX(SAL)>2600;




SELECT SAL FROM SCOTT.EMP GROUP BY SAL HAVING COUNT(*)>1;


SELECT HIREDATE,COUNT(*) FROM SCOTT.EMP GROUP BY HIREDATE HAVING COUNT(*) >1;


SELECT DEPTNO,AVG(SAL) FROM SCOTT.EMP GROUP BY DEPTNO HAVING AVG(SAL)<3000;



SELECT DEPTNO  FROM SCOTT.EMP WHERE ENAME LIKE '%A' OR ENAME LIKE '%S%' GROUP BY DEPTNO HAVING COUNT(*) >=3;



SELECT JOB,MAX(SAL),MIN(SAL) FROM SCOTT.EMP GROUP BY JOB HAVING MAX(SAL)<5000 AND MIN(SAL)>1000;